# ========================================
#              根目录通用忽略
# ========================================

# --- 敏感文件（最重要）---
*.local.properties
application-prod.properties
application-*.local.properties
.env
.env*.local
*.key
secrets.properties

# --- 构建目录 ---
backend/target/
front/dist/
front/.vite/

# --- 依赖目录 ---
front/node_modules/

# --- IDE 和编辑器 ---
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
*.sublime-*

# --- 系统和临时文件 ---
.DS_Store
Thumbs.db
*.log
logs/

# --- 其他常见忽略 ---
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz

# --- 前端特定 ---
front/.env*.local
front/coverage/
front/npm-debug.log*
front/yarn-debug.log*
front/yarn-error.log*

# --- 数据库备份等 ---
*.sql.bak
*.dump

# --- Git 本身 ---
.gitignore.local